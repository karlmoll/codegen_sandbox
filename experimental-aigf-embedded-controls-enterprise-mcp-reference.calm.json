      "opa",
      "observability",
      "logging",
      "metrics",
      "tracing",
      "resilience",
      "vault",
      "finos-air",
      "ai-governance"
    ],
    "description": "A certified architectural pattern for deploying secure, observable, and resilient MCP services in a regulated environment with comprehensive FINOS AIR governance controls."
  },
  "nodes": [
    {
      "unique-id": "external-client",
      "node-type": "application",
      "name": "External Client",
      "description": "The end-user or automated system initiating the MCP request.",
      "interfaces": [{ "unique-id": "external-http" }],
      "controls": {
        "oauth-authorization": {
          "description": "OAuth 2.1 authorization with OIDC, PKCE, and signed JWTs.",
          "requirements": [
            {
              "requirement-url": "https://air-governance-framework.finos.org/calm/control-requirement.json",
              "config-url": "https://air-governance-framework.finos.org/calm/AIR-PREV-012"
            }
          ]
        }
      }
    },
    {
