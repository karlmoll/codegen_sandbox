              "requirement-url": "https://air-governance-framework.finos.org/calm/control-requirement.json",
              "config-url": "https://air-governance-framework.finos.org/calm/AIR-PREV-003"
            }
          ]
        }
      },
      "metadata": {
        "policyLanguage": "rego",
        "defaultDeny": true
      }
    },
    {
      "unique-id": "secrets-vault",
      "node-type": "service",
