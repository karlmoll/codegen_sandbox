          "requirements": [
            {
              "requirement-url": "https://air-governance-framework.finos.org/calm/control-requirement.json",
              "config-url": "https://air-governance-framework.finos.org/calm/AIR-PREV-012"
            }
          ]
        }
      },
      "metadata": {
        "authentication": "OIDC Authorization Code Flow",
        "data": ["MCP Request Body", "Bearer Token (JWT)"]
      }
    },
    {
      "unique-id": "gateway-validates-jwt",
