{
  "calmVersion": "1.0.0",
  "name": "Microsoft Multi-Agent Reference Architecture",
  "description": "A modular and governed multi-agent system reference architecture based on Microsoft's design, supporting local and remote agents, orchestration, and MCP integration. modeled in CALM with FINOS AI Governance Framework controls.",
  "metadata": {
    "owners": [
      "ai-architecture@company.example"
    ],
    "tags": [
      "multi-agent",
      "semantic-kernel",
      "mcp",
      "ai-governance",
      "finos-air"
    ],
    "air-governance": {
      "framework": "FINOS AIR",
      "version": 1.0,
      "reference": "https://air-governance-framework.finos.org/"
    }
  },
  "nodes": [
    {
      "id": "user-application",
      "name": "User Application",
      "type": "Application",
      "description": "Interface layer (Web/Mobile/API) for user interaction.",
      "properties": {
        "authentication": "OIDC/OAuth2",
        "inputValidation": "strict"
      },
      "metadata": {
        "air": {
          "risk-level": "medium",
          "threats": [
            "AIR-SEC-010"
          ],
          "controls": [
            "AIR-PREV-003"
          ]
        }
      }
    },
    {
      "id": "orchestrator",
      "name": "Orchestrator (Semantic Kernel)",
      "type": "Service",
      "description": "Central coordination component managing request flow, context, and agent invocation. Implements Semantic Kernel patterns.",
      "properties": {
        "technology": "Semantic Kernel",
        "responsibilities": [
          "Request/Response Lifecycle",
          "Context Management",
          "Planner/Plugin Execution"
        ]
      },
      "metadata": {
        "air": {
          "risk-level": "critical",
          "threats": [
            "AIR-SEC-010",
            "AIR-OP-020"
          ],
          "controls": [
            "AIR-PREV-003",
            "AIR-CORR-001"
          ]
        }
      }
    },
    {
      "id": "classifier",
      "name": "Classifier",
      "type": "Service",
      "description": "NLU/SLM/LLM component for intent recognition and routing.",
      "properties": {
        "models": [
          "NLU",
          "SLM",
          "LLM"
        ],
        "fallbackStrategy": "NLU -> SLM -> LLM"
      },
      "metadata": {
        "air": {
          "risk-level": "medium"
        }
      }
    },
    {
      "id": "agent-registry",
      "name": "Agent Registry",
      "type": "Service",
      "description": "Discovery and lifecycle management for agents.",
      "properties": {
        "capabilities": [
          "Discovery",
          "Metadata Storage",
          "Health Checks"
        ]
      }
    },
    {
      "id": "storage-layer",
      "name": "Storage Layer",
      "type": "Database",
      "description": "Persistent storage for conversation history and agent state.",
      "properties": {
        "components": [
          "Conversation History (Time-series/NoSQL)",
          "Agent State (Key-Value)"
        ],
        "data-classification": "confidential"
      }
    },
    {
      "id": "supervisor-agent",
      "name": "Supervisor Agent",
      "type": "Service",
      "description": "Specialized agent for coordinating complex tasks and decomposing them for sub-agents.",
      "properties": {
        "role": "supervisor",
        "capabilities": [
          "Task Decomposition",
          "Result Synthesis"
        ]
      },
      "metadata": {
        "air": {
          "risk-level": "high",
          "threats": [
            "AIR-OP-004"
          ],
          "controls": [
            "AIR-DET-004",
            "AIR-DET-005"
          ]
        }
      }
    },
    {
      "id": "specialized-agent-local",
      "name": "Local Agent (Finance/Coding/etc.)",
      "type": "Service",
      "description": "Domain-specific agent running within the orchestrator's environment.",
      "properties": {
        "hosting": "local",
        "capabilities": [
          "Domain Expertise"
        ],
        "mcp-client": "enabled"
      },
      "metadata": {
        "air": {
          "risk-level": "high",
          "threats": [
            "AIR-OP-004",
            "AIR-SEC-002"
          ]
        }
      }
    },
    {
      "id": "specialized-agent-remote",
      "name": "Remote Agent",
      "type": "Service",
      "description": "Domain-specific agent operating across network boundaries.",
      "properties": {
        "hosting": "remote",
        "protocol": "HTTPS/GRPC",
        "mcp-client": "enabled"
      },
      "metadata": {
        "air": {
          "risk-level": "high"
        }
      }
    },
    {
      "id": "knowledge-layer",
      "name": "Knowledge Layer",
      "type": "Database",
      "description": "RAG, Vector DBs, and Knowledge Graphs.",
      "properties": {
        "components": [
          "Vector DB",
          "Knowledge Graph",
          "CMS"
        ]
      },
      "metadata": {
        "air": {
          "threats": [
            "AIR-SEC-001",
            "AIR-SEC-002"
          ],
          "controls": [
            "AIR-PREV-002"
          ]
        }
      }
    },
    {
      "id": "mcp-server",
      "name": "MCP Server / Integration Layer",
      "type": "Service",
      "description": "Standardized interface for external tools via Model Context Protocol.",
      "properties": {
        "protocol": "MCP",
        "transport": "SSE/WebSocket"
      },
      "metadata": {
        "air": {
          "risk-level": "high",
          "threats": [
            "AIR-SEC-010"
          ],
          "controls": [
            "AIR-PREV-003",
            "AIR-PREV-012"
          ]
        }
      }
    }
  ],
  "relationships": [
    {
      "source": "user-application",
      "target": "orchestrator",
      "type": "calls",
      "description": "1. Submit complex query / Forward request",
      "properties": {
        "protocol": "HTTPS"
      }
    },
    {
      "source": "orchestrator",
      "target": "storage-layer",
      "type": "reads_writes",
      "description": "3-4. Load/Store conversation history and context"
    },
    {
      "source": "orchestrator",
      "target": "classifier",
      "type": "calls",
      "description": "5. Classify query"
    },
    {
      "source": "classifier",
      "target": "agent-registry",
      "type": "queries",
      "description": "7. Get matching agents"
    },
    {
      "source": "orchestrator",
      "target": "supervisor-agent",
      "type": "delegates",
      "description": "11. Send user request & agents info"
    },
    {
      "source": "supervisor-agent",
      "target": "specialized-agent-local",
      "type": "delegates",
      "description": "13. Request within agent domain"
    },
    {
      "source": "supervisor-agent",
      "target": "specialized-agent-remote",
      "type": "delegates",
      "description": "14. Request within agent domain"
    },
    {
      "source": "specialized-agent-local",
      "target": "knowledge-layer",
      "type": "queries",
      "description": "15. Query knowledge"
    },
    {
      "source": "specialized-agent-remote",
      "target": "knowledge-layer",
      "type": "queries",
      "description": "17. Query knowledge"
    },
    {
      "source": "specialized-agent-local",
      "target": "mcp-server",
      "type": "calls",
      "description": "Uses external tools via MCP Client"
    },
    {
      "source": "specialized-agent-remote",
      "target": "mcp-server",
      "type": "calls",
      "description": "Uses external tools via MCP Client"
    }
  ],
  "views": [
    {
      "id": "architecture-overview",
      "name": "Microsoft Multi-Agent Architecture Overview",
      "type": "system-landscape",
      "elements": [
        "user-application",
        "orchestrator",
        "classifier",
        "agent-registry",
        "supervisor-agent",
        "specialized-agent-local",
        "specialized-agent-remote",
        "knowledge-layer",
        "storage-layer",
        "mcp-server"
      ],
      "relationships": [
        "user-application->orchestrator",
        "orchestrator->classifier",
        "orchestrator->storage-layer",
        "orchestrator->supervisor-agent",
        "classifier->agent-registry",
        "supervisor-agent->specialized-agent-local",
        "supervisor-agent->specialized-agent-remote",
        "specialized-agent-local->knowledge-layer",
        "specialized-agent-local->mcp-server"
      ]
    }
  ]
}